# NexCode Environment Variables Example
# Copy this file to .env and fill in your actual API keys

# Required for web search capabilities (Tavily MCP Server)
TAVILY_API_KEY=your_tavily_api_key_here

# Required if using Groq as your LLM provider (Recommended default)
GROQ_API_KEY=your_groq_api_key_here

# Required if using OpenAI as your LLM provider
OPENAI_API_KEY=your_openai_api_key_here

# Required if using Anthropic as your LLM provider
ANTHROPIC_API_KEY=your_anthropic_api_key_here
